<% content_for(:page_title) { "Aprovações" } %>

<h1 class="text-2xl font-bold text-slate-900 mb-6">Aprovações</h1>

<div class="mb-6">
  <%= form_with url: admin_approvals_path, method: :get, class: "flex items-center gap-3" do |f| %>
    <%= f.select :client_id,
          [["Todos os clientes", ""]] + @clients.map { |c| [c.name, c.id] },
          { selected: params[:client_id] },
          class: "h-9 px-3 border border-gray-200 rounded-lg text-sm text-slate-700 bg-white" %>

    <%
      decision_labels = {
        "approved"         => "Aprovado",
        "change_requested" => "Pediu Alteração"
      }
      decision_options = [["Todas as decisões", ""]] + ApprovalResponse.decisions.keys.map { |d| [decision_labels[d], d] }
    %>
    <%= f.select :decision,
          decision_options,
          { selected: params[:decision] },
          class: "h-9 px-3 border border-gray-200 rounded-lg text-sm text-slate-700 bg-white" %>

    <%= f.submit "Filtrar",
          class: "h-9 px-4 bg-[#0F7949] hover:bg-[#0a5c37] text-white text-sm font-semibold rounded-lg transition-colors cursor-pointer" %>
  <% end %>
</div>

<% if @approval_responses.empty? %>
  <p class="text-sm text-slate-500 py-4">Nenhuma resposta encontrada.</p>
<% else %>
  <table class="min-w-full bg-white border border-gray-200 rounded-xl shadow-card">
    <thead>
      <tr>
        <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wide">Arte</th>
        <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wide">Cliente</th>
        <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wide">Decisão</th>
        <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wide">Data</th>
        <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wide">Ações</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% @approval_responses.each do |response| %>
        <tr class="hover:bg-slate-50">
          <td class="px-4 py-3 text-sm text-slate-900"><%= response.arte.title.presence || "Sem título" %></td>
          <td class="px-4 py-3 text-sm text-slate-600"><%= response.arte.client.name %></td>
          <td class="px-4 py-3 text-sm text-slate-600"><%= response.decision %></td>
          <td class="px-4 py-3 text-sm text-slate-600">
            <%= response.responded_at&.strftime("%d/%m/%Y %H:%M") %>
          </td>
          <td class="px-4 py-3">
            <%= link_to "Ver Arte", admin_arte_path(response.arte),
                  class: "inline-flex items-center h-8 px-3 border border-gray-200 rounded-lg text-xs text-slate-600 hover:bg-gray-50 transition-colors" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>

<%= pagy_nav(@pagy) if @pagy.pages > 1 %>
