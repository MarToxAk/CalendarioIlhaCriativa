<% content_for(:page_title) { @client.name } %>

<div class="mb-6 flex items-center gap-4">
  <%= link_to admin_clients_path,
        class: "text-sm text-slate-600 hover:text-slate-900 transition-colors" do %>
    &larr; Clientes
  <% end %>
  <%= link_to "Editar cliente", edit_admin_client_path(@client),
        class: "inline-flex items-center h-9 px-3 border border-gray-200 rounded-lg text-sm text-slate-700 hover:bg-gray-50 transition-colors" %>
</div>

<div class="bg-white rounded-xl border border-gray-200 shadow-card p-8 max-w-2xl">
  <h2 class="text-base font-semibold text-slate-900 mb-6">Dados de acesso do portal</h2>

  <div class="space-y-5">
    <%# Link de acesso %>
    <div>
      <label class="block text-sm font-medium text-slate-900 mb-1.5">Link de acesso</label>
      <div class="flex gap-2">
        <input type="text"
               readonly
               value="<%= client_root_url(token: @client.access_token) %>"
               aria-label="Link de acesso do portal"
               aria-readonly="true"
               class="flex-1 h-11 px-3 bg-gray-50 border border-gray-200 rounded-lg text-sm font-mono text-slate-700 select-all cursor-text focus:outline-none" />
        <a href="<%= client_root_url(token: @client.access_token) %>"
           target="_blank"
           rel="noopener noreferrer"
           aria-label="Abrir link de acesso em nova aba"
           class="h-11 w-11 flex items-center justify-center rounded-lg border border-gray-200 bg-white hover:bg-gray-50 text-slate-400 hover:text-slate-600 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    </div>

    <%# Senha do portal %>
    <div>
      <label class="block text-sm font-medium text-slate-900 mb-1.5">Senha do portal</label>
      <div class="relative" data-controller="password-toggle">
        <input type="text"
               readonly
               value="<%= @client.password_plain %>"
               aria-label="Senha do portal do cliente"
               aria-readonly="true"
               data-password-toggle-target="field"
               class="block w-full h-11 px-3 pr-11 bg-gray-50 border border-gray-200 rounded-lg text-sm text-slate-700 select-all cursor-text focus:outline-none" />
        <button type="button"
                aria-label="Ocultar senha"
                aria-pressed="true"
                data-action="click->password-toggle#toggle"
                data-password-toggle-target="toggle"
                class="absolute inset-y-0 right-0 flex items-center px-3 text-slate-400 hover:text-slate-600 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <hr class="my-6 border-gray-200" />

  <%# Rotacionar token %>
  <%= button_to "↻ Rotacionar token de acesso",
        rotate_token_admin_client_path(@client),
        method: :post,
        class: "text-sm text-slate-600 hover:text-red-600 transition-colors" %>
</div>

<div class="bg-white rounded-xl border border-gray-200 shadow-card p-6 max-w-2xl mt-4">
  <h2 class="text-base font-semibold text-slate-900 mb-4">Informações</h2>
  <dl class="space-y-3">
    <div class="flex items-center gap-4">
      <dt class="text-sm text-slate-500 w-32">Status</dt>
      <dd><%= render "status_badge", client: @client %></dd>
    </div>
    <div class="flex items-center gap-4">
      <dt class="text-sm text-slate-500 w-32">Criado em</dt>
      <dd class="text-sm text-slate-700"><%= @client.created_at.strftime("%d/%m/%Y") %></dd>
    </div>
  </dl>
</div>
