<% if client.active %>
  <span class="inline-flex items-center gap-1 px-2 py-1 rounded-full text-xs font-medium border bg-[#F0FDF4] text-[#14A958] border-[#14A958]/20">
    <span aria-hidden="true">●</span> Ativo
  </span>
<% else %>
  <span class="inline-flex items-center gap-1 px-2 py-1 rounded-full text-xs font-medium border bg-[#FFFBEB] text-amber-800 border-[#F59E0B]/20">
    <span aria-hidden="true">●</span> Inativo
  </span>
<% end %>
