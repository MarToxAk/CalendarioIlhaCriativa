<%# app/views/admin/artes/show.html.erb %>
<% content_for(:page_title) { @arte.title || "Arte" } %>

<div class="bg-white rounded-xl border border-gray-200 shadow-card p-6 max-w-2xl">
  <h2 class="text-lg font-semibold mb-4"><%= @arte.title %></h2>
  <p><strong>Cliente:</strong> <%= @arte.client.name %></p>
  <p><strong>Data agendada:</strong> <%= @arte.scheduled_on.strftime("%d/%m/%Y") %></p>
  <p><strong>Plataforma:</strong> <%= @arte.platform.capitalize %></p>
  <p><strong>Status:</strong> <%= @arte.status.capitalize %></p>
  <p><strong>Legenda:</strong> <%= @arte.caption %></p>
  <% if @arte.media_file.attached? %>
    <p><strong>Arquivo:</strong> <%= link_to @arte.media_file.filename, rails_blob_path(@arte.media_file, disposition: "attachment") %></p>
  <% elsif @arte.external_url.present? %>
    <p><strong>Link externo:</strong> <%= link_to @arte.external_url, @arte.external_url, target: "_blank", rel: "noopener noreferrer" %></p>
  <% end %>
  <%# ===== BARRA DE AÇÕES ===== %>
  <div class="flex items-center gap-3 mb-6">
    <%= link_to admin_artes_path,
          aria: { label: "Voltar para lista de artes" },
          class: "text-sm text-slate-600 hover:text-slate-900 transition-colors" do %>
      &larr; Artes
    <% end %>

    <%= link_to "Editar", edit_admin_arte_path(@arte),
          class: "inline-flex items-center h-9 px-3 border border-gray-200 rounded-lg text-sm font-medium text-slate-700 bg-white hover:bg-gray-50 transition-colors" if @arte.pending? || @arte.revised? || @arte.change_requested? %>

    <%= button_to "Excluir", admin_arte_path(@arte),
          method: :delete,
          data: { confirm: "Tem certeza?" },
          class: "inline-flex items-center h-9 px-3 bg-[#EE3537] hover:bg-red-700 text-white text-sm font-medium rounded-lg transition-colors",
          form: { class: "inline" } if @arte.pending? && @arte.approval_responses.none? %>

    <% if @arte.change_requested? %>
      <%= button_to "Marcar como Revisada",
                    mark_revised_admin_arte_path(@arte),
                    method: :patch,
                    class: "inline-flex items-center h-9 px-4 bg-[#0F7949] hover:bg-[#0a5c37] text-white text-sm font-semibold rounded-lg transition-colors",
                    form: { class: "inline", data: { turbo_confirm: "Confirmar: marcar esta arte como revisada?" } } %>
    <% end %>
  </div>
</div>

<% if @arte.change_requested? || @arte.revised? %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-card p-6 max-w-2xl mt-6">
    <h3 class="text-sm font-semibold text-slate-900 border-b border-gray-100 pb-3 mb-4">Resposta interna ao comentário</h3>
    <%= form_with model: [:admin, @arte], method: :patch do |f| %>
      <%= f.text_area :admin_reply,
                      value: @arte.admin_reply,
                      rows: 4,
                      placeholder: "Escreva uma nota interna sobre o pedido de alteração do cliente...",
                      class: "block w-full px-3 py-2 border border-gray-200 rounded-lg text-sm text-slate-700 focus:outline-none focus:ring-2 focus:ring-[#0F7949]/20 focus:border-[#0F7949]" %>
      <div class="mt-3">
        <%= f.submit "Salvar resposta", class: "h-9 px-4 bg-[#0F7949] hover:bg-[#0a5c37] text-white text-sm font-semibold rounded-lg transition-colors cursor-pointer" %>
      </div>
    <% end %>
  </div>
<% end %>
