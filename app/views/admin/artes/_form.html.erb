<%# app/views/admin/artes/_form.html.erb %>
<% button_label ||= arte.persisted? ? "Salvar alterações" : "Criar" %>
<% cancel_path ||= arte.persisted? ? admin_arte_path(arte) : admin_artes_path %>
<%= form_with model: arte, url: arte.persisted? ? admin_arte_path(arte) : admin_artes_path, local: true, html: { multipart: true, data: { controller: "media-type-toggle" } } do |f| %>
  <% if arte.errors[:base].any? %>
    <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700">
      <% arte.errors[:base].each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>
  <div class="mb-4">
    <%= f.label :title, "Título", class: "block text-sm font-medium text-slate-900 mb-1.5" %>
    <%= f.text_field :title, class: "block w-full h-11 px-3 border border-gray-200 rounded-lg text-sm text-slate-900 bg-white focus:outline-none focus:border-[#0F7949] focus:ring-2 focus:ring-[#0F7949]/10 transition-colors placeholder-slate-400" %>
  </div>
  <div class="mb-4">
    <%= f.label :caption, "Legenda", class: "block text-sm font-medium text-slate-900 mb-1.5" %>
    <%= f.text_area :caption, class: "block w-full min-h-[80px] resize-y px-3 py-2 border border-gray-200 rounded-lg text-sm text-slate-900 bg-white focus:outline-none focus:border-[#0F7949] focus:ring-2 focus:ring-[#0F7949]/10 transition-colors placeholder-slate-400" %>
  </div>
  <div class="mb-4">
    <%= f.label :scheduled_on, "Data agendada", class: "block text-sm font-medium text-slate-900 mb-1.5" %>
    <%= f.date_field :scheduled_on, class: "block w-full h-11 px-3 border border-gray-200 rounded-lg text-sm text-slate-900 bg-white focus:outline-none focus:border-[#0F7949] focus:ring-2 focus:ring-[#0F7949]/10 transition-colors placeholder-slate-400" %>
  </div>
  <div class="mb-4">
    <%= f.label :approval_deadline, "Prazo de aprovação", class: "block text-sm font-medium text-slate-900 mb-1.5" %>
    <%= f.date_field :approval_deadline, class: "block w-full h-11 px-3 border border-gray-200 rounded-lg text-sm text-slate-900 bg-white focus:outline-none focus:border-[#0F7949] focus:ring-2 focus:ring-[#0F7949]/10 transition-colors placeholder-slate-400" %>
  </div>
  <div class="mb-4">
    <%= f.label :platform, "Plataforma", class: "block text-sm font-medium text-slate-900 mb-1.5" %>
    <%= f.select :platform, Arte.platforms.keys.map { |k| [k.capitalize, k] }, {}, class: "block w-full h-11 px-3 border border-gray-200 rounded-lg text-sm text-slate-900 bg-white focus:outline-none focus:border-[#0F7949] focus:ring-2 focus:ring-[#0F7949]/10 transition-colors" %>
  </div>
  <div class="mb-4">
    <%= f.label :media_type, "Formato", class: "block text-sm font-medium text-slate-900 mb-1.5" %>
    <%= f.select :media_type, Arte.media_types.keys.map { |k| [k.capitalize, k] }, {}, class: "block w-full h-11 px-3 border border-gray-200 rounded-lg text-sm text-slate-900 bg-white focus:outline-none focus:border-[#0F7949] focus:ring-2 focus:ring-[#0F7949]/10 transition-colors" %>
  </div>
  <div class="mb-4">
    <label class="block text-sm font-medium text-slate-900 mb-1.5">Tipo de mídia</label>
    <div class="flex gap-3">
      <label data-media-type-toggle-target="uploadLabel"
             class="cursor-pointer flex items-center gap-2 px-4 py-2 rounded-lg border border-gray-200 text-sm font-medium transition-colors">
        <%= f.radio_button :media_source, :upload,
              checked: arte.media_file.attached? || arte.external_url.blank?,
              class: "sr-only",
              data: { action: "media-type-toggle#selectUpload", media_type_toggle_target: "uploadRadio" } %>
        Upload de arquivo
      </label>
      <label data-media-type-toggle-target="linkLabel"
             class="cursor-pointer flex items-center gap-2 px-4 py-2 rounded-lg border border-gray-200 text-sm font-medium transition-colors">
        <%= f.radio_button :media_source, :link,
              checked: arte.external_url.present?,
              class: "sr-only",
              data: { action: "media-type-toggle#selectLink", media_type_toggle_target: "linkRadio" } %>
        Link externo
      </label>
    </div>
  </div>
  <div class="<%= (arte.media_file.attached? || arte.external_url.blank?) ? 'mb-4' : 'mb-4 hidden' %>" data-media-type-toggle-target="uploadField">
    <%= f.label :media_file, "Arquivo", class: "block text-sm font-medium text-slate-900 mb-1.5" %>
    <%= f.file_field :media_file, class: "block w-full text-sm text-slate-900 border border-gray-200 rounded-lg cursor-pointer bg-white file:mr-4 file:py-2 file:px-4 file:border-0 file:text-sm file:font-semibold file:bg-green-50 file:text-green-700 hover:file:bg-green-100" %>
  </div>
  <div class="<%= arte.external_url.present? ? 'mb-4' : 'mb-4 hidden' %>" data-media-type-toggle-target="linkField">
    <%= f.label :external_url, "Link externo", class: "block text-sm font-medium text-slate-900 mb-1.5" %>
    <%= f.url_field :external_url, class: "block w-full h-11 px-3 border border-gray-200 rounded-lg text-sm text-slate-900 bg-white focus:outline-none focus:border-[#0F7949] focus:ring-2 focus:ring-[#0F7949]/10 transition-colors placeholder-slate-400" %>
  </div>
  <% if arte.client_id.present? %>
    <%= f.hidden_field :client_id %>
  <% else %>
    <div class="mb-4">
      <%= f.label :client_id, "Cliente", class: "block text-sm font-medium text-slate-900 mb-1.5" %>
      <%= f.select :client_id, Client.order(:name).map { |c| [c.name, c.id] }, { prompt: "Selecione o cliente" }, class: "block w-full h-11 px-3 border border-gray-200 rounded-lg text-sm text-slate-900 bg-white focus:outline-none focus:border-[#0F7949] focus:ring-2 focus:ring-[#0F7949]/10 transition-colors" %>
    </div>
  <% end %>
  <div class="flex justify-end gap-3 pt-2">
    <%= link_to "Voltar sem salvar", cancel_path,
          class: "inline-flex items-center h-10 px-4 border border-gray-200 rounded-lg text-sm text-slate-600 hover:text-slate-900 hover:bg-gray-50 transition-colors" %>
    <%= f.submit button_label,
          class: "h-10 px-4 bg-[#0F7949] hover:bg-[#0a5c37] active:scale-[0.99] text-white text-sm font-semibold rounded-lg transition-colors cursor-pointer" %>
  </div>
<% end %>
